# Spotify Vibe Playlist Generator — backend env
PORT=4000
CLIENT_URL=http://localhost:3000

# Create an app at https://developer.spotify.com/dashboard and fill these in
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:4000/api/auth/callback

# Long random string used to sign the session cookie
SESSION_SECRET=replace_me_with_a_long_random_string
